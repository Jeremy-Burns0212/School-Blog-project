<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - School_Blog_project</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/School_Blog_project.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <!-- Placeholder logo (inline SVG) linking to homepage -->
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index" aria-label="Home">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" role="img" class="d-inline-block align-top" focusable="false" aria-hidden="false">
                        <rect width="100%" height="100%" fill="#6c757d"></rect>
                        <text x="50%" y="50%" fill="#ffffff" font-family="Helvetica, Arial, sans-serif" font-size="10" dominant-baseline="middle" text-anchor="middle">Logo</text>
                    </svg>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Students">Student Stories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Graduates">Graduate Stories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Faculty">Faculty &amp; Staff Stories</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="News">News</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />

                    <!-- Non-functional search input (placeholder only) -->
                    <form class="d-flex ms-3" role="search" onsubmit="return false;">
                        <input class="form-control" type="search" placeholder="Search" aria-label="Search" />
                    </form>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container py-4">
            <div class="row align-items-start">
                <!-- Left: icon -->
                <div class="col-12 col-md-2 mb-3 text-center text-md-start">
                    <div class="avatar rounded-circle bg-secondary text-white d-inline-flex align-items-center justify-content-center"
                         style="width:64px;height:64px;font-weight:600; font-size:1.1rem;">
                        Logo 2
                    </div>
                </div>

                <!-- Middle: About + Categories -->
                <div class="col-12 col-md-7 mb-3">
                    <div class="row">
                        <div class="col-12 col-sm-6 mb-3">
                            <h5>More About [School Acronym]</h5>
                            <ul class="list-unstyled">
                                <li><a class="text-decoration-none text-muted" asp-area="" asp-controller="Home" asp-action="Index">Placeholder Link 1</a></li>
                                <li><a class="text-decoration-none text-muted" asp-area="" asp-controller="Home" asp-action="Index">Placeholder Link 2</a></li>
                                <li><a class="text-decoration-none text-muted" asp-area="" asp-controller="Home" asp-action="Index">Placeholder Link 3</a></li>
                                <li><a class="text-decoration-none text-muted" asp-area="" asp-controller="Home" asp-action="Index">Placeholder Link 4</a></li>
                            </ul>
                        </div>

                        <div class="col-12 col-sm-6 mb-3">
                            <h5>Categories</h5>
                            <ul class="list-unstyled">
                                <li><a class="text-decoration-none text-muted" asp-area="" asp-controller="Home" asp-action="Students">Student Stories</a></li>
                                <li><a class="text-decoration-none text-muted" asp-area="" asp-controller="Home" asp-action="Graduates">Graduate Stories</a></li>
                                <li><a class="text-decoration-none text-muted" asp-area="" asp-controller="Home" asp-action="Faculty">Faculty &amp; Staff Stories</a></li>
                                <li><a class="text-decoration-none text-muted" asp-area="" asp-controller="Home" asp-action="News">News</a></li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Right: blurb -->
                <div class="col-12 col-md-3 mb-3">
                    <p class="text-muted small">Placeholder blurb about the school and the blog.</p>
                </div>
            </div>
        </div>

        <!-- Bottom full-width copyright -->
        <div class="w-100 bg-dark text-white">
            <div class="w-100 bg-dark text-white text-center py-2 small">
                &copy; 2026 - School Blog Project
            </div>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

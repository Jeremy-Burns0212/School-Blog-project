@{
    ViewData["Title"] = "Home";
}

<div class="container py-4">
    <div class="row">
        <!-- Left: Featured area (main) -->
        <main class="col-12 col-lg-8">
            <!-- Large featured placeholder -->
            <section class="mb-4">
                <div class="bg-light border rounded p-3 mb-3" style="min-height:240px;">
                    <div class="row g-3 align-items-center">
                        <div class="bg-light border rounded mb-3 p-0 overflow-hidden">
                            <div class="bg-secondary w-100"
                                 style="aspect-ratio:16/9; background-size:cover; background-position:center;">
                            </div>
                        </div>
                        <div class="col">
                            <h2 class="h4 mb-1">Featured Story Title (placeholder)</h2>
                            <p class="text-muted small mb-2">Jan 1, 2026</p>
                            <a class="btn btn-sm btn-outline-primary" href="#">Read More</a>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Featured Stories heading + three placeholders -->
            <section>
                <h3 class="h5 mb-3">Featured Stories</h3>
                <div class="list-unstyled">

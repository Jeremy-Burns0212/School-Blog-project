@model School_Blog_project.Models.ArticleListingPageViewModel

@{
    // Build the pagination window.
    var startPage = Math.Max(1, Model.CurrentPage - 1);
    var endPage = Math.Min(Model.TotalPages, Model.CurrentPage + 1);
    var showLastPageSeparately = Model.TotalPages > 1 && endPage < Model.TotalPages;
}

<div>
    <!-- Page heading -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">@Model.Heading</h1>
    </div>

    <!-- Article list -->
    <div class="list-group mb-4">
        @foreach (var story in Model.Articles)
        {
            <article class="list-group-item list-group-item-action mb-3 @(story.IsPlaceholder ? "bg-light" : "")"
                     style="@(story.IsPlaceholder ? "border-style:dashed;" : "")">
                <div class="row g-3">
                    <!-- Thumbnail -->
                    <div class="col-12 col-sm-3 d-flex align-items-center justify-content-center">
                        <img src="@story.ImageUrl"
                             alt="@story.Title"
                             class="img-fluid rounded"
                             style="max-width:120px; max-height:80px; object-fit:cover;" />
                    </div>

                    <!-- Story details -->
                    <div class="col-12 col-sm-9">
                        <!-- Title -->
                        <h5 class="mb-1">@story.Title</h5>

                        @if (story.IsPlaceholder)
                        {
                            <!-- Placeholder message -->
                            <p class="text-muted small mb-0">Coming soon</p>
                        }
                        else
                        {
                            <!-- Publish date -->
                            <small class="text-muted">@story.Date.ToString("MMMM d, yyyy")</small>

                            @if (!string.IsNullOrWhiteSpace(story.Description))
                            {
                                <!-- Short summary -->
                                <p class="mb-1 mt-2 text-muted">@story.Description</p>
                            }

                            <!-- Read-more link -->
                            <a class="btn btn-outline-primary btn-sm"
                               asp-controller="Home"
                               asp-action="Articles"
                               asp-route-titleSlug="@story.Slug">
                                Read more
                            </a>
                        }
                    </div>
                </div>
            </article>
        }
    </div>

    <!-- Pagination controls -->
    <nav aria-label="Pagination">
        <ul class="pagination">
            <!-- Previous page -->
            <li class="page-item @(Model.CurrentPage <= 1 ? "disabled" : "")">
                @if (Model.CurrentPage <= 1)
                {
                    <span class="page-link">Previous</span>
                }
                else
                {
                    <a class="page-link" asp-action="@Model.ActionName" asp-route-page="@(Model.CurrentPage - 1)">Previous</a>
                }
            </li>

            <!-- Nearby page numbers -->
            @for (var pageNumber = startPage; pageNumber <= endPage; pageNumber++)
            {
                <li class="page-item @(pageNumber == Model.CurrentPage ? "active" : "")">
                    @if (pageNumber == Model.CurrentPage)
                    {
                        <span class="page-link">@pageNumber</span>
                    }
                    else
                    {
                        <a class="page-link" asp-action="@Model.ActionName" asp-route-page="@pageNumber">@pageNumber</a>
                    }
                </li>
            }

            <!-- Last page shortcut -->
            @if (showLastPageSeparately)
            {
                <li class="page-item disabled">
                    <span class="page-link">...</span>
                </li>

                <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "active" : "")">
                    @if (Model.CurrentPage == Model.TotalPages)
                    {
                        <span class="page-link">@Model.TotalPages</span>
                    }
                    else
                    {
                        <a class="page-link" asp-action="@Model.ActionName" asp-route-page="@Model.TotalPages">@Model.TotalPages</a>
                    }
                </li>
            }

            <!-- Next page -->
            <li class="page-item @(Model.CurrentPage >= Model.TotalPages ? "disabled" : "")">
                @if (Model.CurrentPage >= Model.TotalPages)
                {
                    <span class="page-link">Next</span>
                }
                else
                {
                    <a class="page-link" asp-action="@Model.ActionName" asp-route-page="@(Model.CurrentPage + 1)">Next</a>
                }
            </li>
        </ul>
    </nav>
</div>
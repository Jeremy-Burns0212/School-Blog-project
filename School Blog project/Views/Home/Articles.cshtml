@model School_Blog_project.Models.HomePageArticleViewModel

@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <div class="row">
        <div class="col-12 col-lg-10 mx-auto">
            <div class="border rounded p-3">
                <!-- Display the main article image -->
                <img src="@Model.ImageUrl"
                     alt="@Model.Title"
                     class="img-fluid rounded mb-3 w-100" />

                <!-- Display the article title and publish date -->
                <h1 class="h3 mb-2">@Model.Title</h1>
                <p class="text-muted mb-0">@Model.DatePublished.ToString("MMM d, yyyy")</p>
            </div>
        </div>
    </div>
</div>  
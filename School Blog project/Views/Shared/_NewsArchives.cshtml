@model School_Blog_project.Models.NewsArchivesViewModel

@{
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "News";
}

<div class="card mb-4">
    <!-- Section header -->
    <div class="card-header">News Archives</div>

    <!-- Archive year list -->
    <div class="card-body">
        <ul class="list-unstyled mb-0">
            @foreach (var year in Model.Years)
            {
                <li class="mb-1">
                    <a class="text-decoration-none @(Model.SelectedYear == year ? "fw-semibold" : "")"
                       asp-controller="Home"
                       asp-action="@currentAction"
                       asp-route-year="@year"
                       aria-current="@(Model.SelectedYear == year ? "page" : null)">@year</a>
                </li>
            }
        </ul>
    </div>
</div>
@using Microsoft.AspNetCore.Identity
@using School_Blog_project.Data
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-sm-center">
    @* Signed-in user menu *@
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item dropdown">
            <button class="btn btn-link nav-link text-dark p-0 border-0 shadow-none"
                    id="accountDropdown"
                    type="button"
                    data-bs-toggle="dropdown"
                    aria-expanded="false"
                    aria-label="Account menu">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22" role="img" aria-hidden="true">
                    <rect x="3" y="5" width="16" height="2" rx="1" fill="currentColor" />
                    <rect x="3" y="10" width="16" height="2" rx="1" fill="currentColor" />
                    <rect x="3" y="15" width="16" height="2" rx="1" fill="currentColor" />
                </svg>
            </button>

            @* Dropdown options *@
            <ul class="dropdown-menu dropdown-menu-end shadow-sm mt-2" aria-labelledby="accountDropdown">
                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                        Account Settings
                    </a>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <form class="m-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item">Logout</button>
                    </form>
                </li>
            </ul>
        </li>

        @* Extra menu item for Writer role *@
        @if ((await UserManager.GetUserAsync(User)) is var appUser && appUser != null && await UserManager.IsInRoleAsync(appUser, "Writer"))
        {
            <li class="nav-item ms-sm-2">
                <a class="nav-link text-dark" asp-page="/WriterOnly/Index">Writer Area</a>
            </li>
        }
    }
    else
    {
        @* Links for anonymous users *@
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>